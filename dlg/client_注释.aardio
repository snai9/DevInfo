//============================================================
//  单位资产信息采集系统 —— 客户端主程序
//============================================================
//  本文件是 C/S 架构中客户端的完整实现，由 main.aardio 通过
//  loadcodex("/dlg/client.aardio") 加载执行。
//
//  功能概览：
//      1. 采集本机硬件信息（计算机名、操作系统、IP/MAC、品牌编号、
//         办公软件、杀毒软件、内存、硬盘）
//      2. 显示采集结果到主窗体
//      3. 自动探测可用服务器并上传数据
//      4. 提供修改使用人、服务器设置等交互功能
//
//  整体流程：
//      doCollect() → mainForm.show() → checkServer() → win.loopMessage()
//      启动时先采集 → 显示窗体 → 并行探测服务器 → 进入消息循环
//
//  aardio 规范提醒：
//      1. 所有 import 语句必须放在文件顶部
//      2. DSG 窗体定义块必须放在顶层
//      3. GUI 程序禁止 import console
//      4. 客户端主窗体使用 mainForm（正规 aardio 命名规范）
//============================================================


//============================================================
//  一、import 语句
//============================================================
//  win.ui           窗体基础库，提供 win.form、控件创建等
//  fonts.fontAwesome FontAwesome 图标字体，用于状态栏图标
//  thread.command   线程间消息传递，用于后台线程回调 UI
//  hwinfo.config    配置管理（加载/保存用户信息、服务器地址）
//  hwinfo.collect   硬件信息采集（CPU、内存、硬盘、网络等）
//  hwinfo.upload    数据上传（HTTP POST 到服务端）
//  hwinfo.namedlg   用户信息录入弹窗（使用人、单位、部门）
//============================================================
import win.ui;
import fonts.fontAwesome;
import thread.command;

import hwinfo.config;
import hwinfo.collect;
import hwinfo.upload;
import hwinfo.namedlg;

//============================================================
//  二、DSG 窗体定义
//============================================================
//  aardio 设计器只识别第一个 DSG 块，不可拆分或嵌套。
//
//  颜色规则（重要）：
//      - DSG 中 bgcolor / color 使用 BGR 格式（蓝绿红字节序）
//        例：0xE0F0F8 → B=0xE0, G=0xF0, R=0xF8 → RGB(248,240,224)
//      - plus.skin() 的颜色使用 ARGB 格式，必须带 0xFF alpha 前缀
//        例：0xFFD4A846 → A=0xFF, R=0xD4, G=0xA8, B=0x46
//      - 两者格式不同，切勿混用！
//
//  控件类型说明：
//      plus    增强按钮，支持 skin() 自定义外观（渐变、悬停等）
//      bkplus  背景增强控件，用于状态栏图标/文字（不接收焦点）
//      static  静态文本标签，只显示不可编辑
//      edit    可编辑文本框，multiline=1 时为多行
//      groupbox 分组框，视觉上归类控件
//
//  状态栏控件（底部区域）：
//      statusLine       金色分隔线（0xD4A846 BGR 金色）
//      statusIcon       状态图标（FontAwesome 字体）
//      statusText       状态文字
//      statusServerIcon 服务器图标
//      statusServerText 服务器连接状态文字
//      statusTime       右侧时钟
//      db/dl/dr=1       锚定底边/左边/右边（窗口缩放时跟随）
//
//  字体规则：
//      FontAwesome 图标和中文文字不能混用同一 plus 控件（字体不包含中文字形）
//============================================================
