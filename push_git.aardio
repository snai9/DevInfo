import console;
import process;

var cmd = "git add .";
console.log("执行:", cmd);
var p = process(cmd, {hide:true, workingDir=..io._exedir});
console.log("退出码:", p.exitCode);
console.log("输出:", p.readAll());

cmd = "git status";
console.log("\n执行:", cmd);
p = process(cmd, {hide:true, workingDir=..io._exedir});
console.log("退出码:", p.exitCode);
console.log("输出:", p.readAll());

console.pause(true);
